// Prisma schema for Consulting-App Mini ERP
// Stack: Supabase Postgres (Free Tier) + Prisma
// Conventions: UUID PK, snake_case, soft delete (deleted_at), timestamps

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// RBAC
// ============================================

model Role {
  id            String           @id @default(uuid()) @db.Uuid
  name          String           @unique // founder, officer, partner, finance
  description   String?
  userRoles     UserRole[]
  rolePerms     RolePermission[]
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")

  @@map("roles")
}

model Permission {
  id            String           @id @default(uuid()) @db.Uuid
  key           String           @unique // e.g. proposals.approve
  description   String?
  rolePerms     RolePermission[]
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @db.Uuid @map("role_id")
  permissionId String   @db.Uuid @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// Links Supabase Auth users (auth.users.id) to roles
model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id") // Supabase auth.users.id
  roleId    String   @db.Uuid @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  profile Profile @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ============================================
// Profiles (extends Supabase Auth users)
// ============================================

model Profile {
  id           String    @id @db.Uuid // = auth.users.id
  email        String    @unique
  fullName     String?   @map("full_name")
  phone        String?
  avatarUrl    String?   @map("avatar_url")
  role         String    @default("officer") // founder | officer | partner | finance
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  userRoles   UserRole[]

  leadsAssigned Lead[] @relation("LeadAssignee")
  leadsCreated  Lead[] @relation("LeadCreator")

  clientsCreated Client[] @relation("ClientCreator")

  proposalsCreated  Proposal[] @relation("ProposalCreator")
  proposalsApproved Proposal[] @relation("ProposalApprover")
  projectsCreated   Project[] @relation("ProjectCreator")
  projectPartners   ProjectPartner[]

  @@index([role])
  @@map("profiles")
}

// ============================================
// Clients (ISO consulting customers)
// ============================================

model Client {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique // e.g. CL-2026-0001
  name        String
  npwp        String?   // Indonesian tax number
  address     String?
  pic         Json?     // [{ name, role, email, phone }]
  legalDocs   Json?     // [{ name, type, url }]
  status      String    @default("active") // active | inactive
  createdById String?   @db.Uuid @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  creator    Profile?  @relation("ClientCreator", fields: [createdById], references: [id])
  proposals  Proposal[]
  projects   Project[]

  @@index([status])
  @@index([createdById])
  @@map("clients")
}

// ============================================
// Activity Logging (spatie/laravel-activitylog equivalent)
// ============================================

model ActivityLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorId      String?  @db.Uuid @map("actor_id") // profile/user id
  actorName    String?  @map("actor_name")
  action       String // e.g. proposal.approve
  targetType   String?  @map("target_type") // table name
  targetId     String?  @db.Uuid @map("target_id")
  previousValue Json?   @map("previous_value")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
  @@map("activity_logs")
}

// ============================================
// Proposals
// ============================================

model Proposal {
  id              String         @id @default(uuid()) @db.Uuid
  number          String         @unique // e.g. IBEZA/PROP/2026/07/0001
  clientId        String         @db.Uuid @map("client_id")
  status          String         @default("draft") // draft, waiting_approval, approved, sent, accepted, rejected, expired
  items           ProposalItem[]
  subtotal        Int            @default(0) @map("subtotal") // in IDR cents
  discount        Int            @default(0) @map("discount") // in IDR cents
  tax             Int            @default(0) @map("tax") // in IDR cents
  total           Int            @default(0) @map("total") // in IDR cents
  validUntil      DateTime?      @map("valid_until")
  approvedById    String?        @db.Uuid @map("approved_by_id")
  approvedAt      DateTime?      @map("approved_at")
  sentAt          DateTime?      @map("sent_at")
  acceptedAt      DateTime?      @map("accepted_at")
  rejectedAt      DateTime?      @map("rejected_at")
  createdById     String?        @db.Uuid @map("created_by_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  client          Client         @relation(fields: [clientId], references: [id])
  approver        Profile?       @relation("ProposalApprover", fields: [approvedById], references: [id])
  creator         Profile?       @relation("ProposalCreator", fields: [createdById], references: [id])
  project         Project?

  @@index([status])
  @@index([clientId])
  @@index([createdById])
  @@map("proposals")
}

model ProposalItem {
  id           String   @id @default(uuid()) @db.Uuid
  proposalId   String   @db.Uuid @map("proposal_id")
  service      String
  description  String?
  qty          Int      @default(1)
  unitPrice    Int      @map("unit_price") // in IDR cents
  discountPct  Float    @default(0) @map("discount_pct")
  taxPct       Float    @default(11) @map("tax_pct") // PPN 11%
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  proposal     Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@map("proposal_items")
}

// ============================================
// CRM / Leads
// ============================================

model Lead {
  id             String   @id @default(uuid()) @db.Uuid
  code           String   @unique // e.g. LD-2026-0001
  name           String
  email          String?
  phone          String?
  company        String?
  source         String?  // referral, website, linkedin, etc.
  serviceInterest String? // ISO standard of interest
  status         String   @default("new") // new, contacted, meeting_scheduled, proposal_sent, negotiation, won, lost
  assignedTo     String?  @db.Uuid @map("assigned_to") // profile id
  notes          String?
  estimatedValue Int?     @map("estimated_value") // in IDR
  createdById    String?  @db.Uuid @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  assigned Profile? @relation("LeadAssignee", fields: [assignedTo], references: [id])
  creator  Profile? @relation("LeadCreator", fields: [createdById], references: [id])

  @@index([status])
  @@index([assignedTo])
  @@index([source])
  @@index([createdById])
  @@map("leads")
}

// ============================================
// Projects
// ============================================

model Project {
  id              String    @id @default(uuid()) @db.Uuid
  code            String    @unique // PRJ/YYYY/MM/XXXX
  proposalId      String?   @unique @db.Uuid @map("proposal_id")
  clientId        String    @db.Uuid @map("client_id")
  status          String    @default("preparation") // preparation, gap_assessment, documentation, implementation, internal_audit, certification_audit, closed, cancelled
  value           Int       @default(0) @map("value") // in IDR cents
  operationalCost Int?      @map("operational_cost") // in IDR cents
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  createdById     String?   @db.Uuid @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  client       Client              @relation(fields: [clientId], references: [id])
  proposal     Proposal?           @relation(fields: [proposalId], references: [id])
  creator      Profile?            @relation("ProjectCreator", fields: [createdById], references: [id])
  milestones   ProjectMilestone[]
  deliverables ProjectDeliverable[]
  partners     ProjectPartner[]

  @@index([status])
  @@index([clientId])
  @@index([proposalId])
  @@map("projects")
}

model ProjectMilestone {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @db.Uuid @map("project_id")
  name         String
  description  String?
  dueDate      DateTime? @map("due_date")
  status       String    @default("pending") // pending, in_progress, completed
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverables ProjectDeliverable[]

  @@index([projectId])
  @@map("project_milestones")
}

model ProjectDeliverable {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @db.Uuid @map("project_id")
  milestoneId  String?   @db.Uuid @map("milestone_id")
  name         String
  description  String?
  fileUrl      String?   @map("file_url")
  status       String    @default("pending") // pending, submitted, approved
  dueDate      DateTime? @map("due_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone    ProjectMilestone?  @relation(fields: [milestoneId], references: [id])

  @@index([projectId])
  @@index([milestoneId])
  @@map("project_deliverables")
}

model ProjectPartner {
  id                  String   @id @default(uuid()) @db.Uuid
  projectId           String   @db.Uuid @map("project_id")
  partnerId           String   @db.Uuid @map("partner_id") // Profile id
  role                String?  // e.g. lead_consultant, assessor
  revenuePercentage   Float?   @map("revenue_percentage") // 0-100
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  partner  Profile  @relation(fields: [partnerId], references: [id])

  @@unique([projectId, partnerId])
  @@index([projectId])
  @@index([partnerId])
  @@map("project_partners")
}
