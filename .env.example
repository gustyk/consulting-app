# ============================================
# Consulting-App Environment Variables
# Copy to .env.local and fill with your values
# NEVER commit .env.local (already in .gitignore)
# ============================================

# ---------- Supabase (Auth, DB, Storage) ----------
# Project URL: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Public anon key (safe for client): Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (SERVER ONLY — never expose to client): Project Settings → API → service_role
# Used for admin operations, storage server-side, RLS bypass where allowed
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- Database (Prisma via Connection Pooler) ----------
# Use the Supabase Pooler (Session mode / port 6543) for serverless/edge
# Format: postgresql://postgres:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (for prisma migrate / studio, uses port 5432)
DATABASE_DIRECT_URL="postgresql://postgres:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# ---------- Auth Secrets ----------
# Generate: openssl rand -base64 32
# Used by Next.js middleware / session cookie signing
AUTH_SECRET=your-random-32-byte-secret

# ---------- Inngest (Background Jobs) ----------
# Inngest Dev: run `npx inngest-cli dev` locally
# Inngest Cloud: get keys from https://app.inngest.com
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ---------- Email (Resend — Phase 3) ----------
RESEND_API_KEY=your-resend-api-key
NOTIFICATION_FROM_EMAIL=notifications@yourdomain.com

# ---------- Rate Limiting (Upstash Redis — optional) ----------
UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Company branding for PDFs / emails
COMPANY_NAME="Ibeza Consulting"
COMPANY_LOGO_URL=https://YOUR-PROJECT.supabase.co/storage/v1/object/public/...
